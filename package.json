{
  "name": "chatbot-mvp-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.json src/server.ts",
    "build": "tsup src/server.ts --format esm --dts --clean --out-dir dist",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --tsconfig tsconfig.json src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "setup:voice": "tsx --tsconfig tsconfig.json scripts/setup-elevenlabs.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@hapi/boom": "^10.0.1",
    "@neondatabase/serverless": "^0.10.4",
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "better-auth": "^1.2.7",
    "cheerio": "^1.0.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.3.3",
    "openai": "^4.100.0",
    "pdf-parse": "^1.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/pdf-parse": "^1.1.4",
    "@types/qrcode": "^1.5.6",
    "drizzle-kit": "^0.31.1",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@neondatabase/serverless"
    ]
  }
}
